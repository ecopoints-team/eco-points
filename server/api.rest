# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================

# DEVELOPMENT (Default)
@hostname = localhost
@port = 5000
@adminUrl = http://{{hostname}}:{{port}}
@rewardsUrl = http://{{hostname}}:{{port}}
@rpiUrl = http://{{hostname}}:{{port}}

# PRODUCTION (Uncomment to use)
# @adminUrl = https://www.ecopoints.com
# @rewardsUrl = https://rewards.ecopoints.com
# @rpiUrl = https://api.ecopoints.com

@contentType = application/json
@token = {{login.response.body.token}}

###
# @name health_check_web
GET {{adminUrl}}/api/web/health

###
# @name health_check_rpi
GET {{rpiUrl}}/api/rpi/health

### ============================================================================
### AUTHENTICATION
### ============================================================================

# @name login
POST {{adminUrl}}/api/web/auth/login
Content-Type: {{contentType}}

{
    "email": "admin@example.com",
    "password": "adminpassword"
}

###
# @name me
GET {{adminUrl}}/api/web/auth/me
Authorization: Bearer {{token}}

###
# @name logout
POST {{adminUrl}}/api/web/auth/logout
Authorization: Bearer {{token}}

###
# @name change_password
POST {{adminUrl}}/api/web/auth/change-password
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "currentPassword": "oldpassword",
    "newPassword": "newpassword123"
}

### ============================================================================
### DASHBOARD & STATS
### ============================================================================

# @name dashboard_stats
GET {{adminUrl}}/api/web/dashboard/stats
Authorization: Bearer {{token}}

# @name get_cities
GET {{adminUrl}}/api/web/cities
Authorization: Bearer {{token}}

### ============================================================================
### LOCATIONS (Organizations)
### ============================================================================

# @name get_locations
GET {{adminUrl}}/api/web/locations
Authorization: Bearer {{token}}

###
# @name create_location
POST {{adminUrl}}/api/web/locations
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "name": "New University",
    "fullName": "New University - Main Campus",
    "orgType": "University",
    "streetAddress": "123 Main St",
    "barangay": "Centro",
    "cityId": 1,
    "zipCode": "1000",
    "contactPerson": "John Doe",
    "contactEmail": "contact@univ.edu",
    "contactPhone": "09123456789",
    "status": "Active"
}

###
# @name update_location
PUT {{adminUrl}}/api/web/locations/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "contactPerson": "Jane Doe"
}

###
# @name delete_location
DELETE {{adminUrl}}/api/web/locations/1
Authorization: Bearer {{token}}

### ============================================================================
### USERS
### ============================================================================

# @name get_users
GET {{adminUrl}}/api/web/users?role=user
Authorization: Bearer {{token}}

###
# @name get_single_user
GET {{adminUrl}}/api/web/users/1
Authorization: Bearer {{token}}

###
# @name create_user
POST {{adminUrl}}/api/web/users
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "name": "Student One",
    "username": "student1",
    "email": "student1@univ.edu",
    "password": "password123",
    "role": "user",
    "userType": "student",
    "yearLevel": "Grade 11",
    "locationId": 1
}

###
# @name update_user
PUT {{adminUrl}}/api/web/users/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "phone": "09987654321"
}

###
# @name delete_user
DELETE {{adminUrl}}/api/web/users/1
Authorization: Bearer {{token}}

### ============================================================================
### MACHINES (RVMs)
### ============================================================================

# @name get_machines
GET {{adminUrl}}/api/web/machines
Authorization: Bearer {{token}}

###
# @name create_machine
POST {{adminUrl}}/api/web/machines
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "locationId": 1,
    "name": "Main Gate RVM 1",
    "locationName": "Main Gate",
    "maxCapacity": 200
}

###
# @name update_machine
PUT {{adminUrl}}/api/web/machines/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "isOnline": true
}

###
# @name delete_machine
DELETE {{adminUrl}}/api/web/machines/1
Authorization: Bearer {{token}}

