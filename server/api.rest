# @name update_reward
PUT {{rewardsUrl}}/api/web/rewards/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "pointsRequired": 45
}

###
# @name delete_reward
DELETE {{rewardsUrl}}/api/web/rewards/1
Authorization: Bearer {{token}}

